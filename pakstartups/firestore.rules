rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function validString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }
    // Prevent non-admins from setting role to 'admin'
    function roleNotEscalated() {
      return !('role' in request.resource.data) ||
             request.resource.data.role != 'admin';
    }
    // Prevent owners from self-approving moderation status — admin-only field
    function statusUnchanged() {
      return !('status' in request.resource.data) ||
             request.resource.data.status == resource.data.status;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read profiles (needed for display names, avatars)
      allow read: if isAuth();
      // Users create their own profile — no self-promotion to admin
      allow create: if isOwner(uid) && roleNotEscalated();
      // Users can edit their own profile; admins can change any field including role
      allow update: if (isOwner(uid) && roleNotEscalated()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Startups ─────────────────────────────────────────────────────────────
    match /startups/{startupId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.name, 2, 100)
        && validString(request.resource.data.desc, 10, 500)
        && request.resource.data.ownerId == request.auth.uid
        // New submissions must enter moderation queue
        && request.resource.data.status == 'pending';
      // Owners can edit content fields but cannot self-approve — only admins change status
      allow update: if (isOwner(resource.data.ownerId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── Match Profiles ───────────────────────────────────────────────────────
    match /matchProfiles/{profileId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ─── Connection Requests ──────────────────────────────────────────────────
    match /connections/{connId} {
      // Only the two parties involved can read their connection
      allow read: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.fromUid
        // Must start as pending; can't self-connect
        && request.resource.data.status == 'pending'
        && request.resource.data.fromUid != request.resource.data.toUid;
      // Only the recipient can accept or decline
      allow update: if isAuth()
        && request.auth.uid == resource.data.toUid
        && request.resource.data.status in ['accepted', 'declined'];
      // Either party can withdraw/remove a connection
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      ) || isAdmin();
    }

    // ─── B2B Demands ──────────────────────────────────────────────────────────
    match /b2bDemands/{demandId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      // Owners can edit but cannot flip status themselves
      allow update: if (isOwner(resource.data.ownerId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── B2B Solutions ─────────────────────────────────────────────────────────
    match /b2bSolutions/{solutionId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      allow update: if (isOwner(resource.data.ownerId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── Ideas ────────────────────────────────────────────────────────────────
    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && validString(request.resource.data.desc, 20, 2000)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      allow update: if (isOwner(resource.data.ownerId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

      match /votes/{uid} {
        allow read: if true;
        allow write: if isOwner(uid);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && validString(request.resource.data.body, 1, 2000)
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // ─── Blog Posts ───────────────────────────────────────────────────────────
    match /blogPosts/{postId} {
      // Approved posts are public; authors can read their own pending/rejected posts; admins see all
      allow read: if resource.data.status == 'approved'
        || isOwner(resource.data.authorId)
        || isAdmin();
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        // New posts enter moderation — only admins can approve
        && request.resource.data.status == 'pending'
        && request.resource.data.authorId == request.auth.uid;
      // Authors can edit content but cannot self-approve; only admins change status
      allow update: if (isOwner(resource.data.authorId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ─── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.status == 'pending'
        && request.resource.data.organizerId == request.auth.uid;
      // Organizers can update content but not approval status
      allow update: if (isOwner(resource.data.organizerId) && statusUnchanged()) || isAdmin();
      allow delete: if isOwner(resource.data.organizerId) || isAdmin();

      match /rsvps/{uid} {
        allow read: if true;
        allow write: if isOwner(uid);
      }
    }

    // ─── Knowledge Resources ──────────────────────────────────────────────────
    match /knowledgeResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Only the recipient can read their notifications
      allow read: if isAuth() && request.auth.uid == resource.data.toUid;
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid
        && validString(request.resource.data.toUid, 1, 128)
        // Cannot notify yourself
        && request.resource.data.toUid != request.auth.uid
        && validString(request.resource.data.type, 1, 64)
        && request.resource.data.createdAt is timestamp;
      // Recipients can mark as read or dismiss
      allow update: if isAuth() && request.auth.uid == resource.data.toUid;
      allow delete: if isAuth() && request.auth.uid == resource.data.toUid;
    }

    // ─── Site Config ─────────────────────────────────────────────────────────
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
