rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function validString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }
    // Restrict self-assigned roles to the safe allowlist; only admin can set 'admin'
    function roleNotEscalated() {
      return !('role' in request.resource.data) ||
             request.resource.data.role in ['user', 'founder'];
    }
    // Prevent owners from self-approving moderation status — admin-only field
    function statusUnchanged() {
      return !('status' in request.resource.data) ||
             request.resource.data.status == resource.data.status;
    }
    // Only the listed fields (and no others) are affected by this update
    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }
    // None of the listed fields are affected by this update
    function noneChanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    // Field changed by exactly ±1 (for counter increments/decrements)
    function counterStep(field) {
      let delta = request.resource.data[field] - resource.data[field];
      return delta == 1 || delta == -1;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && roleNotEscalated();
      allow update: if (isOwner(uid) && roleNotEscalated()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Volunteer Applications ──────────────────────────────────────────────
    match /volunteerApplications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Startups ─────────────────────────────────────────────────────────────
    match /startups/{startupId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.name, 2, 100)
        && validString(request.resource.data.desc, 10, 500)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        // Owner can edit content but cannot change ownerId, status, or the views counter
        || (isOwner(resource.data.ownerId)
            && statusUnchanged()
            && noneChanged(['ownerId', 'views']))
        // Anyone (even unauthenticated) may increment views by exactly 1
        || (onlyChanged(['views'])
            && request.resource.data.views is int
            && request.resource.data.views == resource.data.views + 1);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── Match Profiles ───────────────────────────────────────────────────────
    match /matchProfiles/{profileId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      // Owner can update their profile but cannot reassign the uid field
      allow update: if (isOwner(resource.data.uid) && noneChanged(['uid'])) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ─── Connection Requests ──────────────────────────────────────────────────
    match /connections/{connId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending'
        && request.resource.data.fromUid != request.resource.data.toUid;
      // Only the recipient can accept/decline, and only the status field may change
      allow update: if isAuth()
        && request.auth.uid == resource.data.toUid
        && onlyChanged(['status', 'updatedAt'])
        && request.resource.data.status in ['accepted', 'declined'];
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      ) || isAdmin();
    }

    // ─── B2B Demands ──────────────────────────────────────────────────────────
    match /b2bDemands/{demandId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      // Owner can edit content but cannot change ownerId or status
      allow update: if isAdmin()
        || (isOwner(resource.data.ownerId) && statusUnchanged() && noneChanged(['ownerId']));
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── B2B Solutions ─────────────────────────────────────────────────────────
    match /b2bSolutions/{solutionId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      allow update: if isAdmin()
        || (isOwner(resource.data.ownerId) && statusUnchanged() && noneChanged(['ownerId']));
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── Ideas ────────────────────────────────────────────────────────────────
    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && validString(request.resource.data.desc, 20, 2000)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';
      allow update: if isAdmin()
        // Owner can edit content but cannot touch counters or reassign ownership
        || (isOwner(resource.data.ownerId) && statusUnchanged() && noneChanged(['ownerId', 'upvotes', 'comments']))
        // Any authenticated user may upvote/downvote (±1 only)
        || (isAuth() && onlyChanged(['upvotes']) && request.resource.data.upvotes is int && counterStep('upvotes'))
        // Any authenticated user may adjust the comment counter (±1 only)
        || (isAuth() && onlyChanged(['comments']) && request.resource.data.comments is int && counterStep('comments'));
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

      match /votes/{uid} {
        allow read: if true;
        allow write: if isOwner(uid);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && validString(request.resource.data.body, 1, 2000)
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // ─── Blog Posts ───────────────────────────────────────────────────────────
    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'approved'
        || isOwner(resource.data.authorId)
        || isAdmin();
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.status == 'pending'
        && request.resource.data.authorId == request.auth.uid;
      // Author can edit content but cannot self-approve, self-feature, self-pin, or reassign authorship
      allow update: if isAdmin()
        || (isOwner(resource.data.authorId) && statusUnchanged() && noneChanged(['authorId', 'isFeatured', 'isPinnedHome']));
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ─── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth()
        && validString(request.resource.data.title, 5, 200)
        && request.resource.data.status == 'pending'
        && request.resource.data.organizerId == request.auth.uid;
      allow update: if isAdmin()
        // Organizer can edit content but cannot change status, isFeatured, or the rsvpCount counter
        || (isOwner(resource.data.organizerId) && statusUnchanged() && noneChanged(['organizerId', 'rsvpCount', 'isFeatured']))
        // Any authenticated user may RSVP / un-RSVP (±1 only)
        || (isAuth() && onlyChanged(['rsvpCount']) && request.resource.data.rsvpCount is int && counterStep('rsvpCount'));
      allow delete: if isOwner(resource.data.organizerId) || isAdmin();

      match /rsvps/{uid} {
        allow read: if true;
        allow write: if isOwner(uid);
      }
    }

    // ─── Knowledge Resources ──────────────────────────────────────────────────
    match /knowledgeResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── FAQs ─────────────────────────────────────────────────────────────────
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Ecosystem Orgs ───────────────────────────────────────────────────────
    match /ecosystemOrgs/{orgId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Idea Resources ───────────────────────────────────────────────────────
    match /ideaResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.toUid;
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid
        && validString(request.resource.data.toUid, 1, 128)
        && request.resource.data.toUid != request.auth.uid
        && validString(request.resource.data.type, 1, 64)
        && request.resource.data.createdAt is timestamp;
      // Recipient may only mark notification as read; cannot alter sender or type
      allow update: if isAuth()
        && request.auth.uid == resource.data.toUid
        && onlyChanged(['read', 'readAt'])
        && (!('readAt' in request.resource.data) || request.resource.data.readAt is timestamp);
      allow delete: if isAuth() && request.auth.uid == resource.data.toUid;
    }

    // ─── Site Config ─────────────────────────────────────────────────────────
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
